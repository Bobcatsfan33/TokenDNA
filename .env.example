# TokenDNA — Environment variable template
# Copy to .env and fill in your values.
# Never commit .env to version control.

# ── App ───────────────────────────────────────────────────────────────────────
# Set to true ONLY for local development — disables all JWT verification
DEV_MODE=false

# Requests per minute per IP before 429 is returned
RATE_LIMIT_PER_MINUTE=60

# ── OIDC / JWT ────────────────────────────────────────────────────────────────
# Base URL of your identity provider (e.g. https://your-tenant.auth0.com)
OIDC_ISSUER=https://your-idp.example.com

# The audience claim your IDP puts in issued tokens
OIDC_AUDIENCE=https://api.tokendna.example.com

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# How long a user baseline stays cached (seconds)
REDIS_BASELINE_TTL=86400

# How long a revoked token entry lives in Redis (seconds)
REDIS_REVOCATION_TTL=3600

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=tokendna
CLICKHOUSE_SECURE=false

# ── GeoIP ─────────────────────────────────────────────────────────────────────
# Options: ip-api (free, no key needed) | maxmind (offline, requires mmdb file)
GEOIP_PROVIDER=ip-api

# Only required when GEOIP_PROVIDER=maxmind
# GEOIP_MAXMIND_DB_PATH=/data/GeoLite2-City.mmdb

# ── Threat intelligence ───────────────────────────────────────────────────────
# AbuseIPDB — get a free key at https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# How often to refresh the Tor exit node list (seconds)
TOR_REFRESH_INTERVAL=3600

# ── Risk score thresholds (0–100 scale) ──────────────────────────────────────
# Scores ABOVE this threshold → ALLOW
SCORE_THRESHOLD_ALLOW=70

# Scores ABOVE this threshold (and ≤ ALLOW) → STEP_UP (MFA challenge)
SCORE_THRESHOLD_STEP_UP=50

# Scores ABOVE this threshold (and ≤ STEP_UP) → BLOCK (403)
SCORE_THRESHOLD_BLOCK=30

# Scores AT OR BELOW this threshold → REVOKE token + alert
SCORE_THRESHOLD_REVOKE=15

# ── Session anomaly settings ─────────────────────────────────────────────────
# Maximum km/h before flagging impossible travel
IMPOSSIBLE_TRAVEL_SPEED_KMH=900

# Number of distinct devices before flagging session branching
BRANCHING_THRESHOLD=3

# ── Alerts / SIEM webhooks ────────────────────────────────────────────────────
# Generic HTTPS webhook for SIEM (Wazuh, Elastic SIEM, Splunk HEC, etc.)
# SIEM_WEBHOOK_URL=https://your-siem.example.com/webhook
# SIEM_WEBHOOK_SECRET=changeme_use_a_long_random_string

# Slack incoming webhook for human-readable alerts
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# MFA/step-up challenge endpoint (your auth service)
# MFA_CHALLENGE_URL=https://auth.example.com/mfa/challenge

# Token revocation relay endpoint (e.g. Auth0 Management API proxy)
# TOKEN_REVOKE_URL=https://your-idp.example.com/oauth/revoke
