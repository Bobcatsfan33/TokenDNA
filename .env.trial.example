# ── TokenDNA self-host trial ──────────────────────────────────────────────────
# Copy to `.env.trial` and fill in. `.env.trial` is gitignored — never commit it.
#
# Trial mode keeps REAL OIDC authentication ON (unlike DEV_MODE, which bypasses
# it). Your data stays in this container's local volume and is never phoned home.

# Trial affordances (onboarding / import / reset / seed). Does NOT weaken auth.
TOKENDNA_TRIAL_MODE=true

# Real deployment posture — the trial uses real auth. Leave DEV_MODE UNSET.
TOKENDNA_ENV=production

# ── Your IdP (OIDC) — required so your users/agents authenticate ───────────────
OIDC_ISSUER=https://your-idp.example.com
OIDC_AUDIENCE=https://tokendna.your-company.example
# Optional IdP group → TokenDNA role mapping:
# TOKENDNA_OIDC_GROUP_ROLE_MAP_JSON={"tokendna-admins":"admin","tokendna-analysts":"analyst"}

# ── Trial license — unlocks every ent.* feature, time-boxed ───────────────────
# Request a key from the license server's /trial form, then paste it here (or
# mount it as a file via TOKENDNA_LICENSE_FILE). Consumed by modules/trial/
# license.py (Phase T1). Enforcement=warn so an EXPIRED trial degrades
# gracefully (features still visible) instead of hard-locking.
# TOKENDNA_TRIAL_LICENSE_KEY=TDNA1....
TOKENDNA_LICENSE_ENFORCEMENT=warn

# ── Data — single-tenant, local to this container's volume ────────────────────
DATA_DB_PATH=/data/tokendna.db
AUDIT_LOG_PATH=/data/audit.jsonl
# Seed demo fixtures on first boot so the trial isn't empty before you import:
SEED_ON_START=1
# Import size caps (keep the trial light) — wired in Phase T3:
# TRIAL_MAX_AGENTS=500
# TRIAL_MAX_EVENTS=50000

# ── Hosted SHARED demo only (public URL password gate — Phase T5) ─────────────
# Not needed for a self-host trial. Set only for the public "click and watch" demo.
# DEMO_PASSWORD=change-me
