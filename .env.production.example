# TokenDNA production/local-appliance environment template.
# Copy to .env for a self-hosted local control plane deployment.
# Replace every change-me value before starting production services.

DEV_MODE=false
ENVIRONMENT=production
TOKENDNA_ENV=production
# commercial | cmmc_l2 | fedramp_high | dod_il4 | dod_il5 | dod_il6
TOKENDNA_COMPLIANCE_PROFILE=commercial

# Public API/auth settings.
CORS_ORIGINS=https://your-console.example.com
OIDC_ISSUER=https://your-idp.example.com
OIDC_AUDIENCE=https://api.tokendna.example.com
TOKENDNA_OIDC_TENANT_CLAIM=org_id
TOKENDNA_OIDC_ROLE_CLAIM=tokendna_role,role
TOKENDNA_OIDC_GROUPS_CLAIM=roles,groups
TOKENDNA_OIDC_GROUP_ROLE_MAP_JSON={"Security Owners":"owner","SOC Analysts":"analyst"}
TOKENDNA_OIDC_ALLOW_SUB_TENANT_FALLBACK=false
TOKENDNA_SCIM_GROUP_ROLE_MAP_JSON={"Security Owners":"owner","SOC Analysts":"analyst"}

# Production storage must be Postgres. DATA_BACKEND/DATABASE_URL are kept as
# compatibility aliases for existing tools and operators.
TOKENDNA_DB_BACKEND=postgres
DATA_BACKEND=postgres
POSTGRES_PASSWORD=change-me-postgres-password
TOKENDNA_PG_DSN=postgresql://tokendna:change-me-postgres-password@postgres:5432/tokendna
DATABASE_URL=postgresql://tokendna:change-me-postgres-password@postgres:5432/tokendna
TOKENDNA_DB_DUAL_WRITE=false

# Service dependencies.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
REDIS_TLS=false
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=tokendna
CLICKHOUSE_PASSWORD=change-me-clickhouse-password
CLICKHOUSE_DB=tokendna
CLICKHOUSE_SECURE=false

# Production HMAC and trust-authority secrets. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
DNA_HMAC_KEY=change-me-64-hex-dna-hmac-key
AUDIT_HMAC_KEY=change-me-64-hex-audit-hmac-key
ATTESTATION_KEY_BACKEND=software
ATTESTATION_CA_ALG=HS256
ATTESTATION_CA_KEY_ID=tokendna-ca-local-1
ATTESTATION_CA_SECRET=change-me-64-hex-attestation-secret
TOKENDNA_DELEGATION_SECRET=change-me-64-hex-delegation-secret
TOKENDNA_WORKFLOW_SECRET=change-me-64-hex-workflow-secret
TOKENDNA_HONEYPOT_SECRET=change-me-64-hex-honeypot-secret
TOKENDNA_POSTURE_SECRET=change-me-64-hex-posture-secret

# Optional stronger key backends.
SECRETS_BACKEND=env
AWS_REGION=us-east-1
USE_FIPS=false
VAULT_ADDR=https://vault.example.com
VAULT_TOKEN=
VAULT_MOUNT=secret

# Runtime controls.
RATE_LIMIT_PER_MINUTE=60
AUDIT_BACKEND=file
AUDIT_LOG_PATH=/var/log/aegis/audit.jsonl
# DoD/CMMC profiles require AUDIT_BACKEND to include siem and a webhook URL.
# SIEM_WEBHOOK_URL=https://your-siem.example.com/webhook
EDGE_DECISION_SLO_MS=5
EDGE_SLO_VIOLATION_ACTION=allow
NETWORK_INTEL_MIN_OBSERVATIONS=2
NETWORK_INTEL_ANTI_POISONING_MIN_TENANTS=2
NETWORK_INTEL_ANTI_POISONING_CONFIDENCE_THRESHOLD=0.7
NETWORK_INTEL_DECAY_DAYS=30
NETWORK_INTEL_DECAY_RATE_PER_DAY=0.05
