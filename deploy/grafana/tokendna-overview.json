{
  "schemaVersion": 39,
  "version": 1,
  "title": "TokenDNA — Service Overview",
  "uid": "tokendna-overview",
  "tags": ["tokendna", "service"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Datasource",
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Request Rate",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null}
          ]}
        }
      },
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(tokendna_http_requests_total[1m]))",
          "legendFormat": "RPS"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate (5xx)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.001},
            {"color": "red", "value": 0.01}
          ]}
        }
      },
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(tokendna_http_requests_total{status_class=\"5xx\"}[5m])) / clamp_min(sum(rate(tokendna_http_requests_total[5m])), 1)",
          "legendFormat": "5xx ratio"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "p95 Latency (overall)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.25},
            {"color": "red", "value": 0.5}
          ]}
        }
      },
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(tokendna_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Secret Gate Failures (1h)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Should always be 0 in steady state. Pages immediately on increment.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "red", "value": 1}
          ]}
        }
      },
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "targets": [
        {
          "expr": "sum(increase(tokendna_secret_gate_failures_total[1h]))",
          "legendFormat": "failures"
        }
      ]
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "Request Rate by Status Class",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "targets": [
        {
          "expr": "sum by (status_class) (rate(tokendna_http_requests_total[1m]))",
          "legendFormat": "{{status_class}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "p50 / p95 / p99 Latency",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(tokendna_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(tokendna_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(tokendna_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },

    {
      "id": 20,
      "type": "timeseries",
      "title": "Top Routes by RPS",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 13},
      "targets": [
        {
          "expr": "topk(10, sum by (route) (rate(tokendna_http_requests_total[5m])))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "p95 Latency by Route",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 13},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (route, le) (rate(tokendna_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{route}}"
        }
      ]
    },

    {
      "id": 30,
      "type": "timeseries",
      "title": "UIS Events Ingested by Decision",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 21},
      "targets": [
        {
          "expr": "sum by (decision) (rate(tokendna_uis_events_total[5m]))",
          "legendFormat": "{{decision}}"
        }
      ]
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Policy Decisions by Module",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 21},
      "targets": [
        {
          "expr": "sum by (module, decision) (rate(tokendna_policy_decisions_total[5m]))",
          "legendFormat": "{{module}} / {{decision}}"
        }
      ]
    }
  ]
}
